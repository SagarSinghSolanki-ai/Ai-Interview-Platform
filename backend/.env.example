# Server Config
PORT=5000
NODE_ENV=development

# Database Config
# Replace with your actual PostgreSQL URL (local or Supabase/Neon)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ai_interview?schema=public"

# Authentication Config
# Generate a secure string for production
JWT_SECRET="super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="7d"

# Google Gemini API Config
GEMINI_API_KEY="your-gemini-api-key-here"

# Judge0 API / RapidAPI Config
# If using RapidAPI for Judge0, supply your RapidAPI Key.
RAPIDAPI_KEY="your-rapidapi-key-here"
RAPIDAPI_HOST="judge0-extra-languages.p.rapidapi.com"
